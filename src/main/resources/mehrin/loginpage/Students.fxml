<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="550.0" prefWidth="730.0" style="-fx-background-color: #C5D5F3;" stylesheets="@mainStyle.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mehrin.loginpage.StudentsController">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox alignment="TOP_CENTER" prefWidth="137.0" spacing="4" style="-fx-background-color: #143F73;" styleClass="sidebar">

            <Button fx:id="home" onAction="#handleHome" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Home" />

            <Button fx:id="books" onAction="#handleBooks" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Books">
            <font>
               <Font size="14.0" />
            </font></Button>

            <Button fx:id="students" onAction="#handleStudents" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Students">
            <font>
               <Font size="14.0" />
            </font></Button>

            <Button fx:id="issuedBooks" onAction="#handleIssueBook" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Issue Book">
            <font>
               <Font size="14.0" />
            </font></Button>

            <Button fx:id="allIssuedBooks" onAction="#handleAllIssuedBooks" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="All Issued Books">
            <font>
               <Font size="14.0" />
            </font></Button>

            <Button fx:id="announcement" onAction="#handleAnnouncement" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Announcement">
            <font>
               <Font size="14.0" />
            </font></Button>

            <Button fx:id="export" onAction="#handleExport" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Export">
            <font>
               <Font size="14.0" />
            </font></Button>

            <Button fx:id="clearance" onAction="#handleClearance" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Clearance" />

            <Button fx:id="logout" onAction="#handleLogout" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Logout">
            <font>
               <Font size="14.0" />
            </font></Button>
        </VBox>
    </left>

    <!-- ================= MAIN CONTENT ================= -->
    <center>
        <HBox spacing="0" styleClass="main-content">

            <!-- ===== STUDENTS TABLE SECTION ===== -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets bottom="30" left="30" right="15" top="30" />
                </padding>

                <HBox alignment="CENTER_LEFT" />

                <Label styleClass="section-title" text="Students">
                    <font>
                        <Font name="System Bold" size="32" />
                    </font>
                </Label>

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <TextField fx:id="searchField" prefWidth="300" promptText="Search student" styleClass="search-field" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Button onAction="#handleDelete" styleClass="secondary-button" text="🗑 Delete" />
                </HBox>

                <TableView fx:id="studentsTable" styleClass="data-table" VBox.vgrow="ALWAYS">

                    <columns>
                        <TableColumn fx:id="studentIdColumn" text="Student ID" />
                        <TableColumn fx:id="nameColumn" text="Name" />
                        <TableColumn fx:id="phoneColumn" text="Phone" />
                        <TableColumn fx:id="emailColumn" text="Email" />
                        <TableColumn fx:id="registrationColumn" text="Registration" />
                        <TableColumn fx:id="sessionColumn" text="Session" />
                        <TableColumn fx:id="yearColumn" text="Year" />
                        <TableColumn fx:id="semesterColumn" text="Semester" />
                    </columns>

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- ===== STUDENT INFO PANEL ===== -->
            <VBox prefWidth="400" spacing="20" styleClass="info-panel">

                <padding>
                    <Insets bottom="30" left="30" right="30" top="30" />
                </padding>

                <Label styleClass="panel-title" text="Student Information">
                    <font>
                        <Font name="System Bold" size="18" />
                    </font>
                </Label>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="400" vbarPolicy="AS_NEEDED">
                    <VBox spacing="15" style="-fx-background-color: #C5D5F3;">
                        <!-- Student ID -->
                        <VBox spacing="8">
                            <Label style="-fx-font-weight: bold;" text="Student ID" />
                            <TextField fx:id="studentIdField" />
                        </VBox>

                        <!-- Student Name -->
                        <VBox spacing="8">
                            <Label style="-fx-font-weight: bold;" text="Student Name" />
                            <TextField fx:id="studentNameField" />
                        </VBox>

                        <!-- Email -->
                        <VBox spacing="8">
                            <Label style="-fx-font-weight: bold;" text="Email" />
                            <TextField fx:id="emailField" />
                        </VBox>

                        <!-- Phone -->
                        <VBox spacing="8">
                            <Label style="-fx-font-weight: bold;" text="Phone" />
                            <TextField fx:id="phoneField" />
                        </VBox>

                        <!-- Registration -->
                        <VBox spacing="8">
                            <Label style="-fx-font-weight: bold;" text="Registration Number" />
                            <TextField fx:id="registrationField" />
                        </VBox>

                        <!-- Session -->
                        <VBox spacing="8">
                            <Label style="-fx-font-weight: bold;" text="Session" />
                            <TextField fx:id="sessionField" />
                        </VBox>

                        <!-- Year -->
                        <VBox spacing="8">
                            <Label style="-fx-font-weight: bold;" text="Year" />
                            <TextField fx:id="yearField" />
                        </VBox>

                        <!-- Semester -->
                        <VBox spacing="8">
                            <Label style="-fx-font-weight: bold;" text="Semester" />
                            <TextField fx:id="semesterField" />
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />
                    </VBox>
                </ScrollPane>

                <HBox spacing="10">
                    <Button maxWidth="Infinity" onAction="#handleCancel" styleClass="secondary-button" text="Cancel" HBox.hgrow="ALWAYS" />

                    <Button maxWidth="Infinity" onAction="#handleSave" styleClass="primary-button" text="Save" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>
        </HBox>
    </center>

    <!-- ================= TOP BAR ================= -->
    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #0B2A4A; -fx-padding: 14 30;">
            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Rajshahi University of Engineering &amp; Technology" />
        </HBox>
    </top>

</BorderPane>
