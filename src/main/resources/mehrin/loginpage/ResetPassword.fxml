<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" prefHeight="550.0" prefWidth="730.0" spacing="0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mehrin.loginpage.ResetPassController">

    <!-- ================= HEADER ================= -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #0B2A4A; -fx-padding: 14 30;">
        <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Rajshahi University of Engineering &amp; Technology" />
    </HBox>

    <!-- ================= MAIN CONTENT ================= -->
    <StackPane alignment="CENTER" style="-fx-background-color: #C5D5F3;" VBox.vgrow="ALWAYS">

        <!-- ================= RESET PASSWORD CARD ================= -->
        <HBox alignment="CENTER" maxHeight="420" maxWidth="600" prefHeight="420" prefWidth="600" style="-fx-background-color: #E6E9EC; -fx-background-radius: 22; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.25), 18, 0, 0, 8);">

            <!-- ================= LEFT SIDE ================= -->
            <VBox alignment="TOP_LEFT" prefHeight="420.0" prefWidth="368.0" spacing="14" style="-fx-padding: 40;">

                <!-- TITLE -->
                <Label style="-fx-font-size: 28; -fx-font-weight: bold;" text="Reset Password">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>

                <!-- USERNAME/EMAIL FIELD -->
                <Label text="Username or Email">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>
                <TextField fx:id="usernameField" onKeyPressed="#onUsernameKeyPressed" prefHeight="38" promptText="Enter your username or email" style="-fx-font-size: 12; -fx-padding: 10; -fx-border-color: #d0d5e0; -fx-border-radius: 5; -fx-background-radius: 5;" />

                <!-- OLD PASSWORD FIELD -->
                <Label text="Current Password">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>
                <PasswordField fx:id="oldPasswordField" onKeyPressed="#onOldPasswordKeyPressed" prefHeight="38" promptText="Enter your current password" style="-fx-font-size: 12; -fx-padding: 10; -fx-border-color: #d0d5e0; -fx-border-radius: 5; -fx-background-radius: 5;" />

                <!-- NEW PASSWORD FIELD -->
                <Label style="-fx-font-weight: bold;" text="New Password">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>
                <PasswordField fx:id="newPasswordField" onKeyPressed="#onNewPasswordKeyPressed" prefHeight="38" promptText="Enter your new password" style="-fx-font-size: 12; -fx-padding: 10; -fx-border-color: #d0d5e0; -fx-border-radius: 5; -fx-background-radius: 5;" />

                <!-- CONFIRM PASSWORD FIELD -->
                <Label style="-fx-font-weight: bold;" text="Confirm Password">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>
                <PasswordField fx:id="confirmPasswordField" onKeyPressed="#onConfirmPasswordKeyPressed" prefHeight="38" promptText="Confirm your new password" style="-fx-font-size: 12; -fx-padding: 10; -fx-border-color: #d0d5e0; -fx-border-radius: 5; -fx-background-radius: 5;" />

                <!-- BUTTONS -->
                <HBox prefHeight="38.0" prefWidth="288.0" spacing="10">
                    <Button fx:id="resetBtn" onAction="#handleReset" prefHeight="26.0" prefWidth="112.0" style="-fx-background-color: #0B2A4A; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;" text="Reset Password" HBox.hgrow="ALWAYS" />

                    <Button onAction="#backToLogin" prefHeight="26.0" prefWidth="121.0" style="-fx-background-color: #AAAAAA; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;" text="Back to Login" HBox.hgrow="ALWAYS" />
                </HBox>

                <Region VBox.vgrow="ALWAYS" />

            </VBox>

            <!-- ================= RIGHT SIDE: IMAGE ================= -->
            <VBox alignment="CENTER" prefHeight="420.0" prefWidth="193.0" />

        </HBox>

    </StackPane>

</VBox>
