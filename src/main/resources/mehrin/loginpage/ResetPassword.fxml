<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" prefHeight="550.0" prefWidth="730.0" spacing="0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mehrin.loginpage.ResetPassController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #0B2A4A; -fx-padding: 14 30;">
        <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Rajshahi University of Engineering &amp; Technology" />
    </HBox>

    <!-- PAGE BACKGROUND -->
    <StackPane alignment="CENTER" style="-fx-background-color: #C5D5F3;" VBox.vgrow="ALWAYS">

        <!-- CARD -->
        <HBox alignment="CENTER" maxHeight="520" maxWidth="620" prefHeight="520" prefWidth="620" style="-fx-background-color: #E6E9EC; -fx-background-radius: 22;                      -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.25), 18, 0, 0, 8);">

            <!-- LEFT: FORM -->
            <VBox alignment="TOP_LEFT" prefHeight="520.0" prefWidth="400.0" spacing="10" style="-fx-padding: 36;">

                <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0B2A4A;" text="Change Password" />

                <!-- Username -->
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;" text="Username or Email" />
                <TextField fx:id="usernameField" onKeyPressed="#onUsernameKeyPressed" prefHeight="36" promptText="Enter your username or email" style="-fx-background-radius: 6; -fx-border-radius: 6;                                   -fx-border-color: #ccc; -fx-border-width: 1; -fx-padding: 0 10;" />

                <!-- Current Password -->
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;" text="Current Password" />
                <StackPane prefHeight="36">
                    <PasswordField fx:id="oldPasswordField" onKeyPressed="#onOldPasswordKeyPressed" prefHeight="36" promptText="Enter your current password" style="-fx-background-radius: 6; -fx-border-radius: 6;                                           -fx-border-color: #ccc; -fx-border-width: 1;                                           -fx-padding: 0 52 0 10;" />
                    <TextField fx:id="oldPasswordVisible" managed="false" onKeyPressed="#onOldPasswordKeyPressed" prefHeight="36" promptText="Enter your current password" style="-fx-background-radius: 6; -fx-border-radius: 6;                                       -fx-border-color: #ccc; -fx-border-width: 1;                                       -fx-padding: 0 52 0 10;" visible="false" />
                    <Button fx:id="eyeOld" onAction="#toggleOld" style="-fx-background-color: transparent; -fx-border-color: transparent;                                    -fx-text-fill: #2D6A4F; -fx-font-size: 12px;                                    -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 10 0 0;" text="Show" StackPane.alignment="CENTER_RIGHT" />
                </StackPane>

                <!-- New Password -->
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;" text="New Password" />
                <StackPane prefHeight="36">
                    <PasswordField fx:id="newPasswordField" onKeyPressed="#onNewPasswordKeyPressed" prefHeight="36" promptText="Enter your new password" style="-fx-background-radius: 6; -fx-border-radius: 6;                                           -fx-border-color: #ccc; -fx-border-width: 1;                                           -fx-padding: 0 52 0 10;" />
                    <TextField fx:id="newPasswordVisible" managed="false" onKeyPressed="#onNewPasswordKeyPressed" prefHeight="36" promptText="Enter your new password" style="-fx-background-radius: 6; -fx-border-radius: 6;                                       -fx-border-color: #ccc; -fx-border-width: 1;                                       -fx-padding: 0 52 0 10;" visible="false" />
                    <Button fx:id="eyeNew" onAction="#toggleNew" style="-fx-background-color: transparent; -fx-border-color: transparent;                                    -fx-text-fill: #2D6A4F; -fx-font-size: 12px;                                    -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 10 0 0;" text="Show" StackPane.alignment="CENTER_RIGHT" />
                </StackPane>

                <!-- Confirm Password -->
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;" text="Confirm New Password" />
                <StackPane prefHeight="36">
                    <PasswordField fx:id="confirmPasswordField" onKeyPressed="#onConfirmPasswordKeyPressed" prefHeight="36" promptText="Confirm your new password" style="-fx-background-radius: 6; -fx-border-radius: 6;                                           -fx-border-color: #ccc; -fx-border-width: 1;                                           -fx-padding: 0 52 0 10;" />
                    <TextField fx:id="confirmPasswordVisible" managed="false" onKeyPressed="#onConfirmPasswordKeyPressed" prefHeight="36" promptText="Confirm your new password" style="-fx-background-radius: 6; -fx-border-radius: 6;                                       -fx-border-color: #ccc; -fx-border-width: 1;                                       -fx-padding: 0 52 0 10;" visible="false" />
                    <Button fx:id="eyeConfirm" onAction="#toggleConfirm" style="-fx-background-color: transparent; -fx-border-color: transparent;                                    -fx-text-fill: #2D6A4F; -fx-font-size: 12px;                                    -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 10 0 0;" text="Show" StackPane.alignment="CENTER_RIGHT" />
                </StackPane>

                <!-- Buttons -->
                <HBox spacing="10" style="-fx-padding: 6 0 0 0;">
                    <Button onAction="#handleReset" prefHeight="34" prefWidth="140" style="-fx-background-color: #0B2A4A; -fx-text-fill: white;                                    -fx-font-size: 13px; -fx-font-weight: bold;                                    -fx-background-radius: 6; -fx-cursor: hand;" text="Change Password" />
                    <Button onAction="#backToLogin" prefHeight="34" prefWidth="120" style="-fx-background-color: #888; -fx-text-fill: white;                                    -fx-font-size: 13px; -fx-font-weight: bold;                                    -fx-background-radius: 6; -fx-cursor: hand;" text="Back to Login" />
                </HBox>

            </VBox>

        </HBox>
    </StackPane>
</VBox>
