<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="600.0" prefWidth="1000.0" style="-fx-background-color: #C5D5F3;" stylesheets="@mainStyle.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mehrin.loginpage.AnnouncementController">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox alignment="TOP_CENTER" prefWidth="137.0" spacing="4" style="-fx-background-color: #143F73;" styleClass="sidebar">

            <Button onAction="#loadHomePanel" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Home">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#loadBooksPanel" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Books">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#loadStudentPanel" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Students">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#loadIssueBooksPanel" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Issue Book">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#viewAllIssuedBooks" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="All Issued Books">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#loadSendAnnouncementsPanel" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Announcement">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#loadExportDataPanel" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Export">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#loadClearancePanel" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Clearance">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#handleLogout" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Logout">
            <font>
               <Font size="14.0" />
            </font></Button>

        </VBox>
    </left>

    <!-- ================= TOP HEADER ================= -->
    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #0B2A4A; -fx-padding: 14 30;">
            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Rajshahi University of Engineering &amp; Technology" />
        </HBox>
    </top>

    <!-- ================= MAIN CONTENT ================= -->
    <center>
        <HBox spacing="0" styleClass="main-content">

            <!-- ===== LEFT: FORM ===== -->
            <VBox spacing="14" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets bottom="30" left="30" right="15" top="30" />
                </padding>

                <!-- Title -->
                <Label styleClass="section-title" text=" Announcement">
                    <font><Font name="System Bold" size="28" /></font>
                </Label>

                <!-- Announcement Title field -->
                <VBox spacing="5">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 13px;" text="Title" />
                    <TextField fx:id="titleField" prefHeight="36" promptText="Enter announcement title" styleClass="search-field" />
                </VBox>

                <!-- Message field -->
                <VBox spacing="5" VBox.vgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 13px;" text="Message" />
                    <TextArea fx:id="announcementArea" prefHeight="220" promptText="Enter announcement message..." styleClass="search-field" wrapText="true" VBox.vgrow="ALWAYS" />
                </VBox>

                <!-- Date info (shown when an item is selected) -->
                <VBox spacing="4" style="-fx-background-color: #dde8f7; -fx-background-radius: 6;                              -fx-padding: 8 12;">
                    <Label fx:id="postedLabel" style="-fx-text-fill: #2c4a72; -fx-font-size: 12px;" text="" />
                    <Label fx:id="updatedLabel" style="-fx-text-fill: #1a6b3c; -fx-font-size: 12px;" text="" />
                </VBox>

                <!-- Action buttons -->
                <HBox spacing="10">
                    <Button onAction="#handlePost" prefHeight="34" prefWidth="90" style="-fx-font-weight: bold; -fx-background-radius: 6;" text="Post" />
                    <Button onAction="#handleUpdate" prefHeight="34" prefWidth="90" style=": white; -fx-font-weight: bold; -fx-background-radius: 6;" text="Update" />
                    <Button onAction="#handleDelete" prefHeight="34" prefWidth="90" style="-fx-font-weight: bold; -fx-background-radius: 6;" text="Delete" />
                    <Button onAction="#handleClear" prefHeight="34" prefWidth="90" style="-fx-font-weight: bold; -fx-background-radius: 6;" text="Clear" />
                </HBox>

            </VBox>

            <!-- ===== RIGHT: LIST ===== -->
            <VBox prefWidth="370" spacing="12" styleClass="info-panel">
                <padding>
                    <Insets bottom="30" left="20" right="20" top="30" />
                </padding>

                <Label styleClass="panel-title" text="All Announcements">
                    <font><Font name="System Bold" size="18" /></font>
                </Label>

                <!-- List shows custom cells with title + posted + updated -->
                <ListView fx:id="announcementList" style="-fx-background-radius: 8; -fx-border-radius: 8;" styleClass="data-table" VBox.vgrow="ALWAYS" />

            </VBox>

        </HBox>
    </center>

</BorderPane>
