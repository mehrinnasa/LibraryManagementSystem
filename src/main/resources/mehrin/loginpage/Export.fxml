<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="651.0" prefWidth="1000.0" style="-fx-background-color: #C5D5F3;" stylesheets="@mainStyle.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mehrin.loginpage.ExportController">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox alignment="TOP_CENTER" prefWidth="137.0" spacing="4" style="-fx-background-color: #143F73;" styleClass="sidebar">

            <Button onAction="#handleHome" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Home">
                <font><Font size="14" /></font>
            </Button>
            <Button onAction="#handleBooks" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Books">
                <font><Font size="14" /></font>
            </Button>
            <Button onAction="#handleStudents" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Students">
                <font><Font size="14" /></font>
            </Button>
            <Button onAction="#handleIssueBook" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Issue Book">
                <font><Font size="14" /></font>
            </Button>
            <Button onAction="#handleAllIssuedBooks" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="All Issued Books">
                <font><Font size="14" /></font>
            </Button>
            <Button onAction="#handleAnnouncement" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Announcement">
                <font><Font size="14" /></font>
            </Button>
            <Button onAction="#handleExport" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Export">
                <font><Font size="14" /></font>
            </Button>
            <Button onAction="#handleClearance" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Clearance">
                <font><Font size="14" /></font>
            </Button>
            <Button onAction="#logout" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Logout">
                <font><Font size="14" /></font>
            </Button>

        </VBox>
    </left>

    <!-- ================= TOP HEADER ================= -->
    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #0B2A4A; -fx-padding: 14 30;">
            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Rajshahi University of Engineering &amp; Technology" />
        </HBox>
    </top>
   <center>
      <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <VBox spacing="20.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label prefHeight="17.0" prefWidth="121.0" text="Export">
                     <font>
                        <Font name="System Bold" size="32.0" />
                     </font>
                  </Label>
                  <HBox prefHeight="370.0" prefWidth="818.0" spacing="20.0">
                     <children>
                         <VBox spacing="20" HBox.hgrow="ALWAYS">
                             <padding>
                                 <Insets bottom="30" left="30" right="15" top="30" />
                             </padding>

                             <VBox spacing="15" styleClass="export">
                                 <ComboBox fx:id="reportComboBox" prefHeight="30.0" prefWidth="228.0" promptText="Select report" />

                                 <Button fx:id="pdfButton" mnemonicParsing="false" onAction="#exportPDF" prefHeight="42.0" prefWidth="239.0" styleClass="export-button" text="PDF Document">
                                     <font>
                                         <Font name="System Bold" size="14.0" />
                                     </font>
                                 </Button>

                                 <Button fx:id="wordButton" mnemonicParsing="false" onAction="#exportWord" prefHeight="42.0" prefWidth="234.0" style="-fx-background-color: #C5D5F3;" styleClass="export-button" text="Word Document">
                                     <font>
                                         <Font name="System Bold" size="14.0" />
                                     </font>
                                 </Button>

                                 <Button fx:id="excelButton" mnemonicParsing="false" onAction="#exportExcel" prefHeight="42.0" prefWidth="238.0" style="-fx-background-color: #C5D5F3;" styleClass="export-button" text="Excel Document">
                                     <font>
                                         <Font name="System Bold Italic" size="14.0" />
                                     </font>
                                 </Button>
                             </VBox>
                         </VBox>
                         <VBox prefHeight="366.0" prefWidth="536.0" spacing="15" styleClass="info-panel">
                             <padding>
                                 <Insets bottom="30" left="30" right="30" top="30" />
                             </padding>

                             <Label prefHeight="23.0" prefWidth="130.0" styleClass="panel-title" text="Book Information">
                                 <font>
                                     <Font name="System Bold" size="18" />
                                 </font>
                             </Label>

                             <VBox spacing="10">
                                 <Label text="Book Search">
                                     <font>
                                         <Font name="System Bold" size="14.0" />
                                     </font></Label>
                                 <TextField fx:id="bookSearchField" onKeyReleased="#searchBook" promptText="Enter ISBN / barcode" />

                                 <Label text="Book Name">
                                     <font>
                                         <Font name="System Bold" size="14.0" />
                                     </font></Label>
                                 <Text fx:id="bookName" text="Book Title">
                                     <font>
                                         <Font size="14.0" />
                                     </font></Text>

                                 <Label text="Author">
                                     <font>
                                         <Font name="System Bold" size="14.0" />
                                     </font></Label>
                                 <Text fx:id="bookAuthor" text="Book Author">
                                     <font>
                                         <Font size="14.0" />
                                     </font></Text>
                                 <Label text="Publisher">
                                     <font>
                                         <Font name="System Bold" size="14.0" />
                                     </font>
                                 </Label>
                                 <Text fx:id="bookPublisher" strokeType="OUTSIDE" strokeWidth="0.0" text="Publisher">
                                     <font>
                                         <Font size="14.0" />
                                     </font>
                                 </Text>

                                 <Label text="Status">
                                     <font>
                                         <Font name="System Bold" size="14.0" />
                                     </font></Label>
                                 <Text fx:id="availability" text="Availability">
                                     <font>
                                         <Font size="14.0" />
                                     </font></Text>
                             </VBox>
                         </VBox>
                     </children>
                  </HBox>
                  <HBox prefHeight="100.0" prefWidth="200.0" spacing="20.0">
                     <children>
                        <Button mnemonicParsing="false" prefHeight="28.0" prefWidth="73.0" text="Cancel" />
                        <Button mnemonicParsing="false" prefHeight="28.0" prefWidth="73.0" text="Export" />
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="30.0" left="30.0" right="15.0" top="30.0" />
               </padding>
            </VBox>
         </children>
      </HBox>
   </center>

</BorderPane>
