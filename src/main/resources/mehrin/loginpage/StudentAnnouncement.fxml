<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="1000.0"
            style="-fx-background-color: #C5D5F3;"
            stylesheets="@mainStyle.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mehrin.loginpage.StudentAnnouncementController">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox alignment="TOP_CENTER" prefWidth="137.0" spacing="4"
              style="-fx-background-color: #143F73;" styleClass="sidebar">

            <Button fx:id="home"          onAction="#loadHomePanel"          prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Home"><font><Font size="14"/></font></Button>
            <Button fx:id="books"         onAction="#loadBooksPanel"         prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Books"><font><Font size="14"/></font></Button>
            <Button fx:id="addToCart"     onAction="#loadAddToCartBooksPanel" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Add To Cart"><font><Font size="14"/></font></Button>
            <Button fx:id="allIssuedBooks" onAction="#loadAllIssuedBooks"    prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="All Issued Books"><font><Font size="14"/></font></Button>
            <Button fx:id="announcement"  onAction="#loadAnnouncementPanel"  prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Announcement"><font><Font size="14"/></font></Button>
            <Button fx:id="clearance"     onAction="#loadClearancePanel"     prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Clearance"><font><Font size="14"/></font></Button>
            <Button fx:id="logout"        onAction="#logout"                 prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Logout"><font><Font size="14"/></font></Button>

        </VBox>
    </left>

    <!-- TOP HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #0B2A4A; -fx-padding: 14 30;">
            <Label text="Rajshahi University of Engineering &amp; Technology"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <HBox spacing="0" styleClass="main-content">

            <!-- ===== LEFT: FULL ANNOUNCEMENT VIEW ===== -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <padding><Insets bottom="30" left="30" right="15" top="30" /></padding>

                <Label style="-fx-font-weight: bold; -fx-font-size: 32px;" text="Announcement" />

                <!-- Detail card -->
                <VBox spacing="14" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-padding: 28;
                             -fx-background-radius: 8;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">

                    <!-- Title -->
                    <Label fx:id="announcementTitle"
                           wrapText="true" maxWidth="Infinity"
                           style="-fx-font-size: 22px; -fx-font-weight: bold;
                                  -fx-text-fill: #0B2A4A;" />

                    <!-- Divider line -->
                    <Separator />

                    <!-- Message body -->
                    <Label fx:id="announcementMessage"
                           wrapText="true" VBox.vgrow="ALWAYS"
                           style="-fx-font-size: 15px; -fx-text-fill: #2c2c2c;
                                  -fx-line-spacing: 4;" />

                    <Region VBox.vgrow="ALWAYS" />

                    <!-- Date / update info at bottom -->
                    <VBox spacing="3"
                          style="-fx-background-color: #dde8f7; -fx-padding: 8 12;
                                 -fx-background-radius: 6;">
                        <Label fx:id="announcementDateTime"
                               wrapText="true"
                               style="-fx-font-size: 12px; -fx-text-fill: #2c4a72;" />
                    </VBox>

                </VBox>
            </VBox>

            <!-- ===== RIGHT: LIST ===== -->
            <VBox prefWidth="370" spacing="12" styleClass="info-panel">
                <padding><Insets bottom="30" left="20" right="20" top="30" /></padding>

                <Label style="-fx-font-weight: bold; -fx-font-size: 18px;"
                       text="Recent Announcements" />

                <ListView fx:id="announcementList"
                          VBox.vgrow="ALWAYS"
                          style="-fx-background-radius: 8; -fx-border-radius: 8;" />
            </VBox>

        </HBox>
    </center>

</BorderPane>
