<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" prefHeight="550.0" prefWidth="730.0" spacing="0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mehrin.loginpage.LoginController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #0B2A4A; -fx-padding: 14 30;">
        <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Rajshahi University of Engineering &amp; Technology" />
    </HBox>

    <!-- PAGE BACKGROUND -->
    <StackPane alignment="CENTER" style="-fx-background-color: #C5D5F3;" VBox.vgrow="ALWAYS">

        <!-- LOGIN CARD -->
        <HBox alignment="CENTER" maxHeight="440" maxWidth="600" prefHeight="440" prefWidth="600" style="-fx-background-color: #E6E9EC;                      -fx-background-radius: 22;                      -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.25), 18, 0, 0, 8);">

            <!-- LEFT SIDE: FORM -->
            <VBox alignment="CENTER_LEFT" prefHeight="440.0" prefWidth="370.0" spacing="12" style="-fx-padding: 40;">

                <Label style="-fx-font-size: 26px; -fx-font-weight: bold;                               -fx-text-fill: #0B2A4A;" text="Welcome Back" />
                <Label style="-fx-font-size: 12px; -fx-text-fill: #666;" text="Sign in to your account" />

                <!-- Username -->
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px;                               -fx-text-fill: #333;" text="Username or Email" />
                <TextField fx:id="usernameField" onKeyPressed="#onUsernameKeyPressed" prefHeight="38" promptText="Enter your username or email" style="-fx-background-radius: 6; -fx-border-radius: 6;                                   -fx-border-color: #ccc; -fx-border-width: 1;                                   -fx-padding: 0 10;" />

                <!-- Password label row -->
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px;                               -fx-text-fill: #333;" text="Password" />

                <!-- Password input with Show/Hide button -->
                <StackPane prefHeight="38">

                    <PasswordField fx:id="passwordField" onKeyPressed="#onPasswordKeyPressed" prefHeight="38" promptText="Enter your password" style="-fx-background-radius: 6;                                           -fx-border-radius: 6;                                           -fx-border-color: #ccc;                                           -fx-border-width: 1;                                           -fx-padding: 0 52 0 10;" />

                    <TextField fx:id="passwordVisible" managed="false" onKeyPressed="#onPasswordKeyPressed" prefHeight="38" promptText="Enter your password" style="-fx-background-radius: 6;                                       -fx-border-radius: 6;                                       -fx-border-color: #ccc;                                       -fx-border-width: 1;                                       -fx-padding: 0 52 0 10;" visible="false" />

                    <!-- Show / Hide text button -->
                    <Button fx:id="eyeButton" onAction="#togglePasswordVisibility" style="-fx-background-color: transparent;                                    -fx-border-color: transparent;                                    -fx-text-fill: #2D6A4F;                                    -fx-font-size: 12px;                                    -fx-font-weight: bold;                                    -fx-cursor: hand;                                    -fx-padding: 0 10 0 0;" text="Show" StackPane.alignment="CENTER_RIGHT" />
                </StackPane>

                <!-- Login button -->
                <Button fx:id="loggedInToMain" onAction="#handleLogin" prefHeight="36" prefWidth="140" style="-fx-background-color: #0B2A4A;                                -fx-text-fill: white;                                -fx-font-size: 13px;                                -fx-font-weight: bold;                                -fx-background-radius: 6;                                -fx-cursor: hand;" text="Sign In" />

                <Hyperlink fx:id="resetPassword" onAction="#changePass" style="-fx-text-fill: #2D6A4F; -fx-font-size: 12px;" text="Forgot your password?" />

            </VBox>

            <!-- RIGHT SIDE: LOGO -->
            <VBox alignment="CENTER" prefHeight="440.0" prefWidth="193.0" style="-fx-background-radius: 0 22 22 0;">
                <ImageView fx:id="imageView" fitWidth="120" preserveRatio="true">
                    <image>
                        <Image url="@RUET.png" />
                    </image>
                </ImageView>
                <Label style="-fx-font-size: 11px; -fx-text-alignment: center; -fx-wrap-text: true; -fx-padding: 12 16 0 16; -fx-opacity: 0.8;" text="RUET Library Management System">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font></Label>
            </VBox>

        </HBox>
    </StackPane>
</VBox>
