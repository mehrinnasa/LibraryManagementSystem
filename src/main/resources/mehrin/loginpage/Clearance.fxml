<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="550.0" prefWidth="730.0" style="-fx-background-color: #C5D5F3;" stylesheets="@mainStyle.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mehrin.loginpage.ClearanceController">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox alignment="TOP_CENTER" prefWidth="137.0" spacing="4" style="-fx-background-color: #143F73;" styleClass="sidebar">
            <Button onAction="#handleHome" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Home">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#handleBooks" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Books">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#handleStudents" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Students">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#handleIssueBook" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Issue Book">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#handleAllIssuedBooks" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="All Issued Books">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#handleAnnouncement" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Announcement">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#handleExport" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Export">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#handleClearance" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Clearance">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#logout" prefHeight="38" prefWidth="137" styleClass="sidebar-button" text="Logout">
            <font>
               <Font size="14.0" />
            </font></Button>
        </VBox>
    </left>

    <!-- ================= MAIN CONTENT ================= -->
    <center>
        <VBox spacing="20" styleClass="main-content">
            <padding>
                <Insets bottom="30" left="30" right="30" top="30" />
            </padding>

            <Label styleClass="section-title" text="Clearance" textFill="#143f73">
                <font>
                    <Font name="System Bold" size="32" />
                </font>
            </Label>

            <HBox alignment="CENTER_LEFT" spacing="15">
                <TextField fx:id="searchField" prefWidth="400" promptText="Enter Student Name or Book Name..." styleClass="search-field" />
            </HBox>

            <TableView fx:id="clearanceTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="studentNameCol" prefWidth="200" text="Student Name" />
                    <TableColumn fx:id="bookNameCol" prefWidth="200" text="Book Name" />
                    <TableColumn fx:id="borrowedDateCol" prefWidth="120" text="Borrowed Date" />
                    <TableColumn fx:id="dueDateCol" prefWidth="120" text="Due Date" />
                    <TableColumn fx:id="returnDateCol" prefWidth="120" text="Date Returned" />
                    <TableColumn fx:id="lateFeeCol" prefWidth="100" text="Late Fee" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>

    <!-- ================= TOP BAR ================= -->
    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #0B2A4A; -fx-padding: 14 30;">
            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Library Management System" />
        </HBox>
    </top>

</BorderPane>
